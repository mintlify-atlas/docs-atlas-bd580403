  "keyFeatures": [
    "Reaction-based raid signups with automatic waitlist management",
    "Recurring raid schedules with custom intervals and spawn times",
    "Natural language time parsing (tomorrow 7pm, next Friday 6:30)",
    "Unified stats and analytics with participation tracking",
    "Availability tracking with server-wide heatmaps",
    "Time slot polling to find optimal raid times",
    "Customizable raid templates per guild",
    "Role-based permissions and command access control",
    "Smart reminders and auto-close for full raids",
    "SQLite database with migration tools",
    "Performance monitoring with DM-based alerts",
    "Museum signup system with auto-lock"
  ],
  "publicApiSurface": [
    "/create - Interactive raid/museum creation flow",
    "/raid - Management panel (Close, Reopen, Delete, Change Time)",
    "/recurring - Manage recurring raid schedules",
    "/raidsignup - Admin signup edits",
    "/raidinfo - List, view details, or export raids",
    "/stats - User, server, weekly, monthly stats and export",
    "/availability - Record/view availability and find optimal times",
    "/poll - Create time slot polls",
    "/setchannel - Configure raid/museum/audit channels",
    "/settings - Reminder and auto-close configuration",
    "/templates - Enable/disable or rename raid templates",
    "/permissions - Configure role-based permissions",
    "/changelog - View current release notes",
    "/help - Command documentation",
    "/ping - Bot health check",
    "/testalert - Send test alert to bot owner"
  ]
}
